    "helmet": "^7.1.0",
    "openai": "^6.34.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
