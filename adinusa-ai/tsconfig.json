{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "outDir": "out",
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": true,
    "moduleResolution": "Node16",
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": ["src", "__tests__"],
  "exclude": ["node_modules", ".vscode-test"]
}
