{
  "name": "adinusa-ai-monorepo",
  "private": true,
  "description": "Adinusa AI monorepo - VS Code extension with autonomous AI agent backend",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmrashed/adinusa-ai.git"
  },
  "author": {
    "name": "Md Rasheduzzaman",
    "email": "jmrashed@gmail.com",
    "url": "https://github.com/jmrashed"
  },
  "workspaces": [
    "adinusa-ai",
    "backend"
  ],
  "scripts": {
    "install:husky": "husky install",
    "dev:all": "pnpm --parallel dev",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm --filter adinusa-ai check-types",
    "test": "pnpm -r test",
    "test:coverage": "pnpm --filter backend test:coverage",
    "build": "pnpm --filter adinusa-ai package",
    "clean": "pnpm -r clean && rm -rf node_modules && pnpm store prune",
    "reset": "pnpm clean && rm -rf .git/hooks && husky install"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "js-yaml": ">=4.2.0",
      "form-data": ">=4.0.6",
      "qs": ">=6.15.2",
      "brace-expansion": ">=5.0.6"
    }
  },
  "version": "0.4.0"
}
