{
  "name": "adinusa-ai-monorepo",
  "private": true,
  "description": "Adinusa AI monorepo - VS Code extension with autonomous AI agent backend",
  "workspaces": [
    "adinusa-ai",
    "backend"
  ],
  "scripts": {
    "install:husky": "husky install",
    "dev:all": "pnpm --parallel dev",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm --filter adinusa-ai check-types",
    "test": "pnpm -r test",
    "test:coverage": "pnpm --filter backend test:coverage",
    "build": "pnpm --filter adinusa-ai package",
    "clean": "pnpm -r clean && rm -rf node_modules && pnpm store prune",
    "reset": "pnpm clean && rm -rf .git/hooks && husky install"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}

